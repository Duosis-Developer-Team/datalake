    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT COALESCE(SUM(total_clusters), 0) AS \"Clusters\" FROM mv_vmware_datacenter_latest WHERE ('$datacenter' = '' OR datacenter_name IN ($datacenter))",
          "format": "table"
        }
      ],
      "title": "Clusters",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT\n  collection_timestamp AS time,\n  datacenter_name AS metric,\n  cpu_usage_avg_percent AS \"CPU %\"\nFROM raw_vmware_datacenter_metrics_agg m\nWHERE m.data_type = 'vmware_datacenter_metrics_agg'\n  AND collection_timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND ('$datacenter' = '' OR m.datacenter_name IN ($datacenter))\nORDER BY time",
          "format": "time_series"
        }
      ],
      "title": "CPU usage % (time series)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT\n  collection_timestamp AS time,\n  datacenter_name AS metric,\n  memory_usage_avg_percent AS \"Memory %\"\nFROM raw_vmware_datacenter_metrics_agg m\nWHERE m.data_type = 'vmware_datacenter_metrics_agg'\n  AND collection_timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND ('$datacenter' = '' OR m.datacenter_name IN ($datacenter))\nORDER BY time",
          "format": "time_series"
        }
      ],
      "title": "Memory usage % (time series)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 10,
      "description": "Storage utilization over time for root cause analysis.",
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT collection_timestamp AS time, datacenter_name AS metric,\n  (CASE WHEN m.total_storage_bytes_capacity > 0 THEN (m.total_storage_bytes_used::float / m.total_storage_bytes_capacity * 100) ELSE NULL END) AS \"Storage %\"\nFROM raw_vmware_datacenter_metrics_agg m\nWHERE m.data_type = 'vmware_datacenter_metrics_agg'\n  AND collection_timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND ('$datacenter' = '' OR m.datacenter_name IN ($datacenter))\nORDER BY time",
          "format": "time_series"
        }
      ],
      "title": "Storage usage % (time series)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 7,
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent" }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT datacenter_name, COALESCE(cpu_usage_percent, 0) AS \"CPU %\" FROM mv_vmware_datacenter_latest\nWHERE ('$datacenter' = '' OR datacenter_name IN ($datacenter))\nORDER BY \"CPU %\" DESC",
          "format": "table"
        }
      ],
      "title": "CPU usage % by datacenter (current)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent" }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT datacenter_name, COALESCE(memory_usage_percent, 0) AS \"Memory %\" FROM mv_vmware_datacenter_latest\nWHERE ('$datacenter' = '' OR datacenter_name IN ($datacenter))\nORDER BY \"Memory %\" DESC",
          "format": "table"
        }
      ],
      "title": "Memory usage % by datacenter (current)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "id": 9,
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "editorMode": "code",
          "rawSql": "SELECT\n  vcenter_name AS \"vCenter\",\n  datacenter_name AS \"Datacenter\",\n  total_clusters AS \"Clusters\",\n  total_hosts AS \"Hosts\",\n  connected_hosts AS \"Connected\",\n  maintenance_hosts AS \"Maintenance\",\n  total_cpu_ghz AS \"CPU (GHz)\",\n  total_memory_gb AS \"Memory (GB)\",\n  cpu_usage_percent AS \"CPU %\",\n  memory_usage_percent AS \"Mem %\"\nFROM mv_vmware_datacenter_latest\nWHERE ('$datacenter' = '' OR datacenter_name IN ($datacenter))\nORDER BY vcenter_name, datacenter_name",
          "format": "table"
        }
      ],
      "title": "Datacenter capacity and usage",
      "type": "table"
    }
  ],
