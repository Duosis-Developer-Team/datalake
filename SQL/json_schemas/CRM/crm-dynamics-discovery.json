{
  "type": "record",
  "name": "CrmDynamicsDiscovery",
  "namespace": "datalake.crm",
  "doc": "Unified Avro schema for Dynamics 365 CRM discovery: accounts, catalog, realized salesorders + order_details. Sparse records per data_type; missing keys map to null via NiFi PutDatabaseRecord.",
  "fields": [
    { "name": "data_type",      "type": ["null", "string"], "doc": "Entity type identifier for NiFi routing." },
    { "name": "collection_time", "type": ["null", { "type": "long", "logicalType": "timestamp-millis" }], "doc": "Collection run instant, epoch ms UTC (NiFi JDBC -> TIMESTAMPTZ)." },

    { "name": "accountid",      "type": ["null", "string"] },
    { "name": "name",           "type": ["null", "string"] },
    { "name": "accountnumber",  "type": ["null", "string"] },
    { "name": "customertypecode_value", "type": ["null", "long"] },
    { "name": "customertypecode_text",  "type": ["null", "string"] },
    { "name": "parentaccountid",        "type": ["null", "string"] },
    { "name": "parentaccount_name",     "type": ["null", "string"] },
    { "name": "primarycontactid",       "type": ["null", "string"] },
    { "name": "primarycontact_name",    "type": ["null", "string"] },
    { "name": "ownerid",               "type": ["null", "string"] },
    { "name": "owner_name",            "type": ["null", "string"] },
    { "name": "statecode",             "type": ["null", "long"] },
    { "name": "statecode_text",        "type": ["null", "string"] },
    { "name": "statuscode",            "type": ["null", "long"] },
    { "name": "statuscode_text",       "type": ["null", "string"] },
    { "name": "telephone1",            "type": ["null", "string"] },
    { "name": "address1_line1",        "type": ["null", "string"] },
    { "name": "address1_city",         "type": ["null", "string"] },
    { "name": "address1_country",      "type": ["null", "string"] },
    { "name": "industrycode",          "type": ["null", "long"] },
    { "name": "industrycode_text",     "type": ["null", "string"] },
    { "name": "revenue",               "type": ["null", "double"] },
    { "name": "numberofemployees",     "type": ["null", "long"] },
    { "name": "transactioncurrencyid", "type": ["null", "string"] },
    { "name": "transactioncurrency_text", "type": ["null", "string"] },
    { "name": "exchangerate",          "type": ["null", "double"] },
    { "name": "createdon",             "type": ["null", { "type": "long", "logicalType": "timestamp-millis" }] },
    { "name": "modifiedon",            "type": ["null", { "type": "long", "logicalType": "timestamp-millis" }] },

    { "name": "productid",             "type": ["null", "string"] },
    { "name": "productnumber",         "type": ["null", "string"] },
    { "name": "defaultuomid",          "type": ["null", "string"] },
    { "name": "defaultuomid_name",     "type": ["null", "string"] },
    { "name": "currentcost",           "type": ["null", "double"] },
    { "name": "standardcost",          "type": ["null", "double"] },
    { "name": "pricelevelid",          "type": ["null", "string"] },
    { "name": "pricelevel_name",       "type": ["null", "string"] },
    { "name": "blt_productgroup",      "type": ["null", "long"] },
    { "name": "blt_productgroup_text", "type": ["null", "string"] },
    { "name": "blt_productmodel",      "type": ["null", "long"] },
    { "name": "blt_productmodel_text", "type": ["null", "string"] },
    { "name": "blt_sectionorder",      "type": ["null", "long"] },

    { "name": "productpricelevelid",   "type": ["null", "string"] },
    { "name": "uomid",                 "type": ["null", "string"] },
    { "name": "uomid_name",            "type": ["null", "string"] },
    { "name": "amount",                "type": ["null", "double"] },
    { "name": "discounttypeid",        "type": ["null", "string"] },
    { "name": "pricingmethodcode",     "type": ["null", "long"] },
    { "name": "pricingmethodcode_text","type": ["null", "string"] },

    { "name": "customerid",            "type": ["null", "string"] },
    { "name": "customerid_name",       "type": ["null", "string"] },
    { "name": "opportunityid",         "type": ["null", "string"] },
    { "name": "quoteid",               "type": ["null", "string"] },
    { "name": "totalamount",           "type": ["null", "double"] },
    { "name": "totaltax",              "type": ["null", "double"] },
    { "name": "totallineitemamount",   "type": ["null", "double"] },
    { "name": "submitdate",            "type": ["null", "string"] },
    { "name": "fulfilldate",           "type": ["null", "string"] },

    { "name": "salesorderid",          "type": ["null", "string"] },
    { "name": "ordernumber",           "type": ["null", "string"] },

    { "name": "salesorderdetailid",    "type": ["null", "string"] },
    { "name": "productdescription",    "type": ["null", "string"] },
    { "name": "quantity",              "type": ["null", "double"] },
    { "name": "priceperunit",          "type": ["null", "double"] },
    { "name": "baseamount",            "type": ["null", "double"] },
    { "name": "extendedamount",        "type": ["null", "double"] },
    { "name": "manualdiscountamount",  "type": ["null", "double"] },

    { "name": "begindate",             "type": ["null", "string"] },
    { "name": "enddate",               "type": ["null", "string"] }
  ]
}
